[include]
	path = ~/.config/delta/themes/catppuccin.gitconfig
[user]
	name = air-plus
	email = jyin1221@gmail.com
	signingkey = 8D980E6DA8C82B71
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	features = catppuccin-mocha
	navigate = true
[merge]
	conflictStyle = zdiff3
[commit]
	gpgsign = true
